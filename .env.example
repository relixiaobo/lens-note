# Copy this file to .env and fill in your keys
# cp .env.example .env

# Required: Anthropic API key for LLM extraction
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (v0.2+ multi-provider support)
OPENAI_API_KEY=sk-proj-...

# Optional: Voyage AI API key for embeddings (v0.2+)
VOYAGE_API_KEY=pa-...
