{
  "name": "lens-note",
  "version": "1.14.1",
  "description": "Knowledge graph CLI for humans and agents. Like Git for knowledge.",
  "type": "module",
  "bin": {
    "lens": "dist/main.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx/esm --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/turndown": "^5.0.6",
    "defuddle": "^0.15.0",
    "feedsmith": "^2.9.1",
    "linkedom": "^0.18.12",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "turndown": "^7.2.4",
    "typescript": "^5.9.0",
    "ulid": "^3.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "knowledge",
    "zettelkasten",
    "cli",
    "agent",
    "notes",
    "graph",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/relixiaobo/lens-note"
  }
}
